<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                    xmlns:controls="clr-namespace:MozaControls">

    <ResourceDictionary.MergedDictionaries>
        <ResourceDictionary Source="pack://application:,,,/MozaPlugin;component/Themes/MozaTheme.xaml"/>
        <ResourceDictionary Source="pack://application:,,,/MozaPlugin;component/Themes/MozaIcons.xaml"/>
    </ResourceDictionary.MergedDictionaries>

    <!-- Converters -->
    <controls:EmptyStringToVisibilityConverter x:Key="EmptyStringToVisibility"/>

    <!-- ============================================================ -->
    <!-- OffOnToggle                                                   -->
    <!-- ============================================================ -->

    <Style TargetType="{x:Type controls:OffOnToggle}">
        <Setter Property="Cursor" Value="Hand"/>
        <Setter Property="Foreground" Value="{StaticResource TextBrush}"/>
        <Setter Property="FontFamily" Value="{StaticResource FontUi}"/>
        <Setter Property="FontSize" Value="12"/>
        <Setter Property="MinHeight" Value="34"/>
        <Setter Property="HorizontalAlignment" Value="Left"/>
        <Setter Property="VerticalAlignment" Value="Center"/>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="{x:Type controls:OffOnToggle}">
                    <StackPanel Orientation="Horizontal">
                        <!-- Content label (only visible when the toggle was given Content="..."),
                             rendered to the left of the pill so it acts as a drop-in for any
                             CheckBox with a Content text. EmptyStringToVisibility hides the
                             column when Content is empty. -->
                        <ContentPresenter x:Name="Lbl"
                                          VerticalAlignment="Center"
                                          Margin="0,0,12,0"
                                          TextBlock.Foreground="{TemplateBinding Foreground}"
                                          TextBlock.FontFamily="{TemplateBinding FontFamily}"
                                          TextBlock.FontSize="{TemplateBinding FontSize}"
                                          Visibility="{Binding Content, RelativeSource={RelativeSource TemplatedParent},
                                                       Converter={StaticResource EmptyStringToVisibility}}"/>
                        <Border x:Name="Bd"
                                Background="{StaticResource BgDeepBrush}"
                                BorderBrush="{StaticResource BorderBrightBrush}"
                                BorderThickness="1"
                                CornerRadius="5"
                                Padding="3"
                                SnapsToDevicePixels="True">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" MinWidth="42"/>
                                    <ColumnDefinition Width="*" MinWidth="42"/>
                                </Grid.ColumnDefinitions>
                                <Border x:Name="OffPill" Grid.Column="0"
                                        Background="Transparent"
                                        CornerRadius="3"
                                        Padding="14,6">
                                    <TextBlock Text="OFF"
                                               x:Name="OffText"
                                               HorizontalAlignment="Center"
                                               VerticalAlignment="Center"
                                               FontSize="12"
                                               FontWeight="SemiBold"
                                               Foreground="{StaticResource TextDimBrush}"/>
                                </Border>
                                <Border x:Name="OnPill" Grid.Column="1"
                                        Background="Transparent"
                                        CornerRadius="3"
                                        Padding="14,6">
                                    <TextBlock Text="ON"
                                               x:Name="OnText"
                                               HorizontalAlignment="Center"
                                               VerticalAlignment="Center"
                                               FontSize="12"
                                               FontWeight="SemiBold"
                                               Foreground="{StaticResource TextDimBrush}"/>
                                </Border>
                            </Grid>
                        </Border>
                    </StackPanel>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsChecked" Value="True">
                            <Setter TargetName="OnPill" Property="Background" Value="{StaticResource ToggleOnBrush}"/>
                            <Setter TargetName="OnPill" Property="BorderBrush" Value="{StaticResource BorderGlowBrush}"/>
                            <Setter TargetName="OnText" Property="Foreground" Value="{StaticResource CyanBrush}"/>
                        </Trigger>
                        <Trigger Property="IsChecked" Value="False">
                            <Setter TargetName="OffPill" Property="Background" Value="{StaticResource BgCardBrush}"/>
                            <Setter TargetName="OffText" Property="Foreground" Value="{StaticResource TextBrush}"/>
                        </Trigger>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter TargetName="Bd" Property="BorderBrush" Value="{StaticResource BorderGlowBrush}"/>
                        </Trigger>
                        <Trigger Property="IsEnabled" Value="False">
                            <Setter TargetName="Bd" Property="Opacity" Value="0.45"/>
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <!-- ============================================================ -->
    <!-- SegmentedControl — horizontal radio-group list                -->
    <!-- ============================================================ -->

    <Style x:Key="SegmentedItemStyle" TargetType="ListBoxItem">
        <Setter Property="Cursor" Value="Hand"/>
        <Setter Property="Foreground" Value="{StaticResource TextDimBrush}"/>
        <Setter Property="FontFamily" Value="{StaticResource FontUi}"/>
        <Setter Property="FontSize" Value="12"/>
        <Setter Property="FontWeight" Value="SemiBold"/>
        <Setter Property="Padding" Value="14,6"/>
        <Setter Property="Margin" Value="2,0,0,0"/>
        <Setter Property="HorizontalContentAlignment" Value="Center"/>
        <Setter Property="VerticalContentAlignment" Value="Center"/>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="ListBoxItem">
                    <Border x:Name="Bd"
                            Background="Transparent"
                            CornerRadius="3"
                            Padding="{TemplateBinding Padding}"
                            SnapsToDevicePixels="True">
                        <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"
                                          TextBlock.Foreground="{TemplateBinding Foreground}"
                                          TextBlock.FontFamily="{TemplateBinding FontFamily}"
                                          TextBlock.FontSize="{TemplateBinding FontSize}"
                                          TextBlock.FontWeight="{TemplateBinding FontWeight}"/>
                    </Border>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter Property="Foreground" Value="{StaticResource TextBrush}"/>
                        </Trigger>
                        <Trigger Property="IsSelected" Value="True">
                            <Setter TargetName="Bd" Property="Background" Value="{StaticResource ToggleOnBrush}"/>
                            <Setter TargetName="Bd" Property="BorderBrush" Value="{StaticResource BorderGlowBrush}"/>
                            <Setter Property="Foreground" Value="{StaticResource CyanBrush}"/>
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <Style TargetType="{x:Type controls:SegmentedControl}">
        <Setter Property="Background" Value="{StaticResource BgDeepBrush}"/>
        <Setter Property="BorderBrush" Value="{StaticResource BorderBrightBrush}"/>
        <Setter Property="BorderThickness" Value="1"/>
        <Setter Property="HorizontalAlignment" Value="Left"/>
        <Setter Property="VerticalAlignment" Value="Center"/>
        <Setter Property="Padding" Value="3"/>
        <Setter Property="ItemContainerStyle" Value="{StaticResource SegmentedItemStyle}"/>
        <Setter Property="ScrollViewer.HorizontalScrollBarVisibility" Value="Hidden"/>
        <Setter Property="ScrollViewer.VerticalScrollBarVisibility" Value="Disabled"/>
        <Setter Property="ItemsPanel">
            <Setter.Value>
                <ItemsPanelTemplate>
                    <StackPanel Orientation="Horizontal"/>
                </ItemsPanelTemplate>
            </Setter.Value>
        </Setter>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="{x:Type controls:SegmentedControl}">
                    <Border Background="{TemplateBinding Background}"
                            BorderBrush="{TemplateBinding BorderBrush}"
                            BorderThickness="{TemplateBinding BorderThickness}"
                            CornerRadius="5"
                            Padding="{TemplateBinding Padding}"
                            SnapsToDevicePixels="True">
                        <ItemsPresenter/>
                    </Border>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <!-- ============================================================ -->
    <!-- MozaCurveEditor                                               -->
    <!-- ============================================================ -->

    <Style TargetType="{x:Type controls:MozaCurveEditor}">
        <Setter Property="MinHeight" Value="280"/>
        <Setter Property="AccentBrush" Value="{StaticResource CyanBrush}"/>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="{x:Type controls:MozaCurveEditor}">
                    <Border Background="{StaticResource BgDeepBrush}"
                            BorderBrush="{StaticResource BorderBrush}"
                            BorderThickness="1"
                            CornerRadius="6"
                            Padding="0"
                            SnapsToDevicePixels="True">
                        <Grid>
                            <!-- Y-axis labels -->
                            <StackPanel HorizontalAlignment="Left" VerticalAlignment="Stretch"
                                        Margin="6,14,0,32" Width="26">
                                <TextBlock Text="100" Style="{StaticResource KvKeyText}" TextAlignment="Right" Width="22"/>
                                <TextBlock Text="75"  Style="{StaticResource KvKeyText}" TextAlignment="Right" Width="22" Margin="0,40,0,0"/>
                                <TextBlock Text="50"  Style="{StaticResource KvKeyText}" TextAlignment="Right" Width="22" Margin="0,40,0,0"/>
                                <TextBlock Text="25"  Style="{StaticResource KvKeyText}" TextAlignment="Right" Width="22" Margin="0,40,0,0"/>
                                <TextBlock Text="0"   Style="{StaticResource KvKeyText}" TextAlignment="Right" Width="22" Margin="0,40,0,0"/>
                            </StackPanel>
                            <!-- X-axis labels -->
                            <Grid VerticalAlignment="Bottom" Margin="36,0,14,8" Height="14">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <TextBlock Grid.Column="0" Text="0"   Style="{StaticResource KvKeyText}" TextAlignment="Left"/>
                                <TextBlock Grid.Column="1" Text="20"  Style="{StaticResource KvKeyText}" TextAlignment="Center"/>
                                <TextBlock Grid.Column="2" Text="40"  Style="{StaticResource KvKeyText}" TextAlignment="Center"/>
                                <TextBlock Grid.Column="3" Text="60"  Style="{StaticResource KvKeyText}" TextAlignment="Center"/>
                                <TextBlock Grid.Column="4" Text="80"  Style="{StaticResource KvKeyText}" TextAlignment="Center"/>
                                <TextBlock Grid.Column="5" Text="100" Style="{StaticResource KvKeyText}" TextAlignment="Right"/>
                            </Grid>
                            <!-- Canvas (drag surface + spline render) -->
                            <Canvas x:Name="PART_Canvas" Background="Transparent" ClipToBounds="True">
                                <!-- Grid lines -->
                                <Path Stroke="{StaticResource BorderBrush}" StrokeThickness="1"
                                      StrokeDashArray="2 3" Opacity="0.6"
                                      Data="{Binding GridGeometry, RelativeSource={RelativeSource TemplatedParent}}"/>
                                <!-- Curve -->
                                <Path Stroke="{TemplateBinding AccentBrush}" StrokeThickness="2.5"
                                      StrokeStartLineCap="Round" StrokeEndLineCap="Round"
                                      Fill="{x:Null}"
                                      Effect="{StaticResource CyanGlowSoftEffect}"
                                      Data="{Binding CurveGeometry, RelativeSource={RelativeSource TemplatedParent}}"/>
                                <!-- 5 nodes -->
                                <Ellipse Width="14" Height="14"
                                         Fill="{StaticResource BgDeepBrush}"
                                         Stroke="{TemplateBinding AccentBrush}" StrokeThickness="2"
                                         Canvas.Left="{Binding Node1X, RelativeSource={RelativeSource TemplatedParent}}"
                                         Canvas.Top="{Binding Node1Y, RelativeSource={RelativeSource TemplatedParent}}"
                                         Effect="{StaticResource CyanGlowSoftEffect}"/>
                                <Ellipse Width="14" Height="14"
                                         Fill="{StaticResource BgDeepBrush}"
                                         Stroke="{TemplateBinding AccentBrush}" StrokeThickness="2"
                                         Canvas.Left="{Binding Node2X, RelativeSource={RelativeSource TemplatedParent}}"
                                         Canvas.Top="{Binding Node2Y, RelativeSource={RelativeSource TemplatedParent}}"
                                         Effect="{StaticResource CyanGlowSoftEffect}"/>
                                <Ellipse Width="14" Height="14"
                                         Fill="{StaticResource BgDeepBrush}"
                                         Stroke="{TemplateBinding AccentBrush}" StrokeThickness="2"
                                         Canvas.Left="{Binding Node3X, RelativeSource={RelativeSource TemplatedParent}}"
                                         Canvas.Top="{Binding Node3Y, RelativeSource={RelativeSource TemplatedParent}}"
                                         Effect="{StaticResource CyanGlowSoftEffect}"/>
                                <Ellipse Width="14" Height="14"
                                         Fill="{StaticResource BgDeepBrush}"
                                         Stroke="{TemplateBinding AccentBrush}" StrokeThickness="2"
                                         Canvas.Left="{Binding Node4X, RelativeSource={RelativeSource TemplatedParent}}"
                                         Canvas.Top="{Binding Node4Y, RelativeSource={RelativeSource TemplatedParent}}"
                                         Effect="{StaticResource CyanGlowSoftEffect}"/>
                                <Ellipse Width="14" Height="14"
                                         Fill="{StaticResource BgDeepBrush}"
                                         Stroke="{TemplateBinding AccentBrush}" StrokeThickness="2"
                                         Canvas.Left="{Binding Node5X, RelativeSource={RelativeSource TemplatedParent}}"
                                         Canvas.Top="{Binding Node5Y, RelativeSource={RelativeSource TemplatedParent}}"
                                         Effect="{StaticResource CyanGlowSoftEffect}"/>
                            </Canvas>
                        </Grid>
                    </Border>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <!-- ============================================================ -->
    <!-- MozaEqualizer                                                 -->
    <!-- ============================================================ -->

    <Style x:Key="EqBarBaseStyle" TargetType="Border">
        <Setter Property="Background" Value="{StaticResource EqBarFillBrush}"/>
        <Setter Property="Effect" Value="{StaticResource CyanGlowSoftEffect}"/>
        <Setter Property="CornerRadius" Value="2"/>
        <Setter Property="VerticalAlignment" Value="Bottom"/>
        <Setter Property="HorizontalAlignment" Value="Stretch"/>
        <Setter Property="Margin" Value="2"/>
    </Style>

    <Style TargetType="{x:Type controls:MozaEqualizer}">
        <Setter Property="MinHeight" Value="200"/>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="{x:Type controls:MozaEqualizer}">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="*"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>
                        <Grid x:Name="PART_BarGrid" Grid.Row="0" Background="Transparent" Cursor="SizeNS">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <Border Grid.Column="0" Background="{StaticResource BgDeepBrush}"
                                    BorderBrush="{StaticResource BorderBrush}" BorderThickness="1"
                                    CornerRadius="4" Margin="6">
                                <Border Style="{StaticResource EqBarBaseStyle}"
                                        Height="{Binding Bar1Height, RelativeSource={RelativeSource TemplatedParent}}"/>
                            </Border>
                            <Border Grid.Column="1" Background="{StaticResource BgDeepBrush}"
                                    BorderBrush="{StaticResource BorderBrush}" BorderThickness="1"
                                    CornerRadius="4" Margin="6">
                                <Border Style="{StaticResource EqBarBaseStyle}"
                                        Height="{Binding Bar2Height, RelativeSource={RelativeSource TemplatedParent}}"/>
                            </Border>
                            <Border Grid.Column="2" Background="{StaticResource BgDeepBrush}"
                                    BorderBrush="{StaticResource BorderBrush}" BorderThickness="1"
                                    CornerRadius="4" Margin="6">
                                <Border Style="{StaticResource EqBarBaseStyle}"
                                        Height="{Binding Bar3Height, RelativeSource={RelativeSource TemplatedParent}}"/>
                            </Border>
                            <Border Grid.Column="3" Background="{StaticResource BgDeepBrush}"
                                    BorderBrush="{StaticResource BorderBrush}" BorderThickness="1"
                                    CornerRadius="4" Margin="6">
                                <Border Style="{StaticResource EqBarBaseStyle}"
                                        Height="{Binding Bar4Height, RelativeSource={RelativeSource TemplatedParent}}"/>
                            </Border>
                            <Border Grid.Column="4" Background="{StaticResource BgDeepBrush}"
                                    BorderBrush="{StaticResource BorderBrush}" BorderThickness="1"
                                    CornerRadius="4" Margin="6">
                                <Border Style="{StaticResource EqBarBaseStyle}"
                                        Height="{Binding Bar5Height, RelativeSource={RelativeSource TemplatedParent}}"/>
                            </Border>
                            <Border Grid.Column="5" Background="{StaticResource BgDeepBrush}"
                                    BorderBrush="{StaticResource BorderBrush}" BorderThickness="1"
                                    CornerRadius="4" Margin="6">
                                <Border Style="{StaticResource EqBarBaseStyle}"
                                        Height="{Binding Bar6Height, RelativeSource={RelativeSource TemplatedParent}}"/>
                            </Border>
                        </Grid>
                        <Grid Grid.Row="1" Margin="0,6,0,0">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <StackPanel Grid.Column="0" HorizontalAlignment="Center">
                                <TextBlock Text="{Binding Bar1Label, RelativeSource={RelativeSource TemplatedParent}}"
                                           HorizontalAlignment="Center" Style="{StaticResource MutedHintText}"/>
                                <TextBlock Text="{Binding Band1, RelativeSource={RelativeSource TemplatedParent}, StringFormat={}{0}%}"
                                           HorizontalAlignment="Center" Style="{StaticResource ValueText}" Background="{x:Null}" Padding="0" MinWidth="0"/>
                            </StackPanel>
                            <StackPanel Grid.Column="1" HorizontalAlignment="Center">
                                <TextBlock Text="{Binding Bar2Label, RelativeSource={RelativeSource TemplatedParent}}"
                                           HorizontalAlignment="Center" Style="{StaticResource MutedHintText}"/>
                                <TextBlock Text="{Binding Band2, RelativeSource={RelativeSource TemplatedParent}, StringFormat={}{0}%}"
                                           HorizontalAlignment="Center" Style="{StaticResource ValueText}" Background="{x:Null}" Padding="0" MinWidth="0"/>
                            </StackPanel>
                            <StackPanel Grid.Column="2" HorizontalAlignment="Center">
                                <TextBlock Text="{Binding Bar3Label, RelativeSource={RelativeSource TemplatedParent}}"
                                           HorizontalAlignment="Center" Style="{StaticResource MutedHintText}"/>
                                <TextBlock Text="{Binding Band3, RelativeSource={RelativeSource TemplatedParent}, StringFormat={}{0}%}"
                                           HorizontalAlignment="Center" Style="{StaticResource ValueText}" Background="{x:Null}" Padding="0" MinWidth="0"/>
                            </StackPanel>
                            <StackPanel Grid.Column="3" HorizontalAlignment="Center">
                                <TextBlock Text="{Binding Bar4Label, RelativeSource={RelativeSource TemplatedParent}}"
                                           HorizontalAlignment="Center" Style="{StaticResource MutedHintText}"/>
                                <TextBlock Text="{Binding Band4, RelativeSource={RelativeSource TemplatedParent}, StringFormat={}{0}%}"
                                           HorizontalAlignment="Center" Style="{StaticResource ValueText}" Background="{x:Null}" Padding="0" MinWidth="0"/>
                            </StackPanel>
                            <StackPanel Grid.Column="4" HorizontalAlignment="Center">
                                <TextBlock Text="{Binding Bar5Label, RelativeSource={RelativeSource TemplatedParent}}"
                                           HorizontalAlignment="Center" Style="{StaticResource MutedHintText}"/>
                                <TextBlock Text="{Binding Band5, RelativeSource={RelativeSource TemplatedParent}, StringFormat={}{0}%}"
                                           HorizontalAlignment="Center" Style="{StaticResource ValueText}" Background="{x:Null}" Padding="0" MinWidth="0"/>
                            </StackPanel>
                            <StackPanel Grid.Column="5" HorizontalAlignment="Center">
                                <TextBlock Text="{Binding Bar6Label, RelativeSource={RelativeSource TemplatedParent}}"
                                           HorizontalAlignment="Center" Style="{StaticResource MutedHintText}"/>
                                <TextBlock Text="{Binding Band6, RelativeSource={RelativeSource TemplatedParent}, StringFormat={}{0}%}"
                                           HorizontalAlignment="Center" Style="{StaticResource ValueText}" Background="{x:Null}" Padding="0" MinWidth="0"/>
                            </StackPanel>
                        </Grid>
                    </Grid>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <!-- ============================================================ -->
    <!-- SteeringArc                                                   -->
    <!-- ============================================================ -->

    <Style TargetType="{x:Type controls:SteeringArc}">
        <Setter Property="Width" Value="220"/>
        <Setter Property="Height" Value="220"/>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="{x:Type controls:SteeringArc}">
                    <Grid Width="220" Height="220">
                        <!-- background arc reference (faint full sweep) -->
                        <Path Stroke="{StaticResource BorderBrush}" StrokeThickness="3"
                              StrokeStartLineCap="Round" StrokeEndLineCap="Round" Fill="{x:Null}">
                            <Path.Data>
                                <PathGeometry>
                                    <PathFigure StartPoint="44.97,175.03" IsClosed="False">
                                        <ArcSegment Point="175.03,175.03" Size="92,92"
                                                    SweepDirection="Clockwise" IsLargeArc="True"/>
                                    </PathFigure>
                                </PathGeometry>
                            </Path.Data>
                        </Path>
                        <!-- active arc -->
                        <Path Data="{Binding ArcGeometry, RelativeSource={RelativeSource TemplatedParent}}"
                              StrokeThickness="3"
                              StrokeStartLineCap="Round" StrokeEndLineCap="Round"
                              Fill="{x:Null}"
                              Effect="{StaticResource CyanGlowEffect}">
                            <Path.Stroke>
                                <LinearGradientBrush StartPoint="0,1" EndPoint="1,0">
                                    <GradientStop Color="{StaticResource CyanColor}" Offset="0"/>
                                    <GradientStop Color="{StaticResource GreenColor}" Offset="1"/>
                                </LinearGradientBrush>
                            </Path.Stroke>
                        </Path>
                        <!-- 0° reference notch (green) -->
                        <Path Stroke="{StaticResource GreenBrush}" StrokeThickness="2"
                              Effect="{StaticResource GreenGlowEffect}"
                              Data="M 110 14 L 110 22"/>
                        <!-- centre readout -->
                        <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center">
                            <TextBlock Text="{Binding AngleText, RelativeSource={RelativeSource TemplatedParent}}"
                                       FontFamily="{StaticResource FontMono}"
                                       FontSize="42"
                                       Foreground="{StaticResource CyanBrush}"
                                       FontWeight="Medium"
                                       HorizontalAlignment="Center"/>
                            <TextBlock Text="STEERING ANGLE"
                                       FontFamily="{StaticResource FontUi}"
                                       FontSize="10"
                                       Foreground="{StaticResource TextFaintBrush}"
                                       HorizontalAlignment="Center"
                                       Margin="0,4,0,0"/>
                        </StackPanel>
                        <!-- position dot at end of active arc -->
                        <Canvas IsHitTestVisible="False">
                            <Ellipse Width="8" Height="8"
                                     Fill="{StaticResource CyanBrush}"
                                     Effect="{StaticResource CyanGlowEffect}"
                                     Canvas.Left="{Binding DotX, RelativeSource={RelativeSource TemplatedParent}}"
                                     Canvas.Top="{Binding DotY, RelativeSource={RelativeSource TemplatedParent}}"/>
                        </Canvas>
                    </Grid>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <!-- ============================================================ -->
    <!-- TempCell                                                      -->
    <!-- ============================================================ -->

    <Style TargetType="{x:Type controls:TempCell}">
        <Setter Property="MinHeight" Value="78"/>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="{x:Type controls:TempCell}">
                    <Border Background="{StaticResource BgCard2Brush}"
                            BorderBrush="{StaticResource BorderBrush}"
                            BorderThickness="1"
                            CornerRadius="5"
                            Padding="12">
                        <StackPanel>
                            <TextBlock Text="{TemplateBinding Label}"
                                       FontSize="11"
                                       FontFamily="{StaticResource FontUi}"
                                       Foreground="{StaticResource TextFaintBrush}"
                                       Margin="0,0,0,4"/>
                            <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                                <TextBlock x:Name="ValueLabel"
                                           Text="{Binding ValueText, RelativeSource={RelativeSource TemplatedParent}}"
                                           FontFamily="{StaticResource FontMono}"
                                           FontSize="24"
                                           Foreground="{StaticResource TextBrush}"/>
                                <TextBlock Text="{TemplateBinding Unit}"
                                           FontFamily="{StaticResource FontMono}"
                                           FontSize="12"
                                           Foreground="{StaticResource TextDimBrush}"
                                           VerticalAlignment="Bottom"
                                           Margin="4,0,0,3"/>
                            </StackPanel>
                            <Grid Height="4" Margin="0,10,0,0">
                                <Border CornerRadius="2"
                                        Background="{StaticResource BgDeepBrush}"/>
                                <Border CornerRadius="2"
                                        Background="{StaticResource TempMeterBrush}"
                                        Opacity="0.85"/>
                            </Grid>
                        </StackPanel>
                    </Border>
                    <ControlTemplate.Triggers>
                        <Trigger Property="State" Value="warn">
                            <Setter TargetName="ValueLabel" Property="Foreground" Value="{StaticResource AmberBrush}"/>
                        </Trigger>
                        <Trigger Property="State" Value="danger">
                            <Setter TargetName="ValueLabel" Property="Foreground" Value="{StaticResource RedBrush}"/>
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <!-- ============================================================ -->
    <!-- BandwidthSparkline                                            -->
    <!-- ============================================================ -->

    <Style TargetType="{x:Type controls:BandwidthSparkline}">
        <Setter Property="MinHeight" Value="56"/>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="{x:Type controls:BandwidthSparkline}">
                    <Grid>
                        <Path Data="{Binding FillGeometry, RelativeSource={RelativeSource TemplatedParent}}"
                              StrokeThickness="0">
                            <Path.Fill>
                                <LinearGradientBrush StartPoint="0,0" EndPoint="0,1">
                                    <GradientStop Color="{StaticResource CyanColor}" Offset="0"/>
                                    <GradientStop Color="#0000E5FF" Offset="1"/>
                                </LinearGradientBrush>
                            </Path.Fill>
                        </Path>
                        <Path Data="{Binding LineGeometry, RelativeSource={RelativeSource TemplatedParent}}"
                              Stroke="{TemplateBinding LineBrush}"
                              StrokeThickness="1.5"
                              StrokeStartLineCap="Round"
                              StrokeEndLineCap="Round"
                              Effect="{StaticResource CyanGlowSoftEffect}"
                              Fill="{x:Null}"/>
                        <Canvas IsHitTestVisible="False">
                            <Ellipse Width="6" Height="6"
                                     Fill="{TemplateBinding LineBrush}"
                                     Canvas.Left="{Binding TipX, RelativeSource={RelativeSource TemplatedParent}}"
                                     Canvas.Top="{Binding TipY, RelativeSource={RelativeSource TemplatedParent}}"
                                     Effect="{StaticResource CyanGlowEffect}"/>
                        </Canvas>
                    </Grid>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <!-- ============================================================ -->
    <!-- ConnectionPill                                                -->
    <!-- ============================================================ -->

    <Style TargetType="{x:Type controls:ConnectionPill}">
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="{x:Type controls:ConnectionPill}">
                    <Border x:Name="Outer"
                            Background="{StaticResource BgCardBrush}"
                            BorderBrush="{StaticResource BorderBrush}"
                            BorderThickness="1"
                            CornerRadius="999"
                            Padding="12,6">
                        <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                            <Ellipse x:Name="Dot" Width="8" Height="8"
                                     Fill="#FF555555"
                                     VerticalAlignment="Center"
                                     Margin="0,0,9,0"/>
                            <TextBlock x:Name="PortText"
                                       Text="{TemplateBinding PortName}"
                                       FontFamily="{StaticResource FontMono}"
                                       FontSize="12"
                                       Foreground="{StaticResource TextFaintBrush}"
                                       VerticalAlignment="Center"
                                       Margin="0,0,6,0"/>
                            <TextBlock x:Name="StatusLabel"
                                       Text="{TemplateBinding StatusText}"
                                       FontFamily="{StaticResource FontMono}"
                                       FontSize="12"
                                       Foreground="{StaticResource TextBrush}"
                                       VerticalAlignment="Center"/>
                        </StackPanel>
                    </Border>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsConnected" Value="True">
                            <Setter TargetName="Dot" Property="Fill" Value="{StaticResource GreenBrush}"/>
                            <Setter TargetName="Dot" Property="Effect" Value="{StaticResource GreenGlowEffect}"/>
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <!-- ============================================================ -->
    <!-- PaletteStrip                                                  -->
    <!-- ============================================================ -->

    <Style TargetType="{x:Type controls:PaletteStrip}">
        <Setter Property="MinHeight" Value="32"/>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="{x:Type controls:PaletteStrip}">
                    <StackPanel x:Name="PART_Swatches" Orientation="Horizontal"/>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <!-- ============================================================ -->
    <!-- KnobRingViz                                                   -->
    <!-- ============================================================ -->

    <Style TargetType="{x:Type controls:KnobRingViz}">
        <Setter Property="Width" Value="100"/>
        <Setter Property="Height" Value="100"/>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="{x:Type controls:KnobRingViz}">
                    <Canvas x:Name="PART_Canvas" Width="100" Height="100"
                            Background="Transparent"/>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <!-- ============================================================ -->
    <!-- SectionCard                                                   -->
    <!-- ============================================================ -->

    <Style TargetType="{x:Type controls:SectionCard}">
        <Setter Property="Background" Value="{StaticResource BgCardBrush}"/>
        <Setter Property="BorderBrush" Value="{StaticResource BorderBrush}"/>
        <Setter Property="BorderThickness" Value="1"/>
        <Setter Property="Margin" Value="0,0,0,14"/>
        <Setter Property="AccentBrush" Value="{StaticResource CyanBrush}"/>
        <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="{x:Type controls:SectionCard}">
                    <Border Background="{TemplateBinding Background}"
                            BorderBrush="{TemplateBinding BorderBrush}"
                            BorderThickness="{TemplateBinding BorderThickness}"
                            CornerRadius="8"
                            SnapsToDevicePixels="True">
                        <DockPanel LastChildFill="True">
                            <!-- Header -->
                            <Border DockPanel.Dock="Top"
                                    BorderBrush="{StaticResource BorderBrush}"
                                    BorderThickness="0,0,0,1"
                                    Padding="18,12">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="Auto"/>
                                        <ColumnDefinition Width="Auto"/>
                                        <ColumnDefinition Width="Auto"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>
                                    <!-- Accent bar -->
                                    <Rectangle Grid.Column="0"
                                               Width="2"
                                               Margin="-12,-2,12,-2"
                                               Fill="{TemplateBinding AccentBrush}"
                                               Effect="{StaticResource CyanGlowSoftEffect}"
                                               VerticalAlignment="Stretch"/>
                                    <!-- Icon chip -->
                                    <Border Grid.Column="1"
                                            Width="30" Height="30"
                                            Background="{StaticResource BgCard2Brush}"
                                            BorderBrush="{StaticResource BorderBrightBrush}"
                                            BorderThickness="1"
                                            CornerRadius="5"
                                            Margin="0,0,12,0">
                                        <Path Width="16" Height="16"
                                              Stretch="Uniform"
                                              Stroke="{TemplateBinding AccentBrush}"
                                              StrokeThickness="1.5"
                                              Fill="{x:Null}"
                                              StrokeLineJoin="Round"
                                              StrokeStartLineCap="Round"
                                              StrokeEndLineCap="Round"
                                              Data="{TemplateBinding Icon}"
                                              VerticalAlignment="Center"
                                              HorizontalAlignment="Center"/>
                                    </Border>
                                    <!-- Title + subtitle -->
                                    <StackPanel Grid.Column="2" Orientation="Horizontal"
                                                VerticalAlignment="Center">
                                        <TextBlock Text="{TemplateBinding Title}"
                                                   Style="{StaticResource SectionTitleText}"/>
                                        <TextBlock Text="{TemplateBinding Subtitle}"
                                                   Style="{StaticResource SectionSubText}"
                                                   Visibility="{Binding Subtitle, RelativeSource={RelativeSource TemplatedParent}, Converter={StaticResource EmptyStringToVisibility}}"/>
                                    </StackPanel>
                                    <!-- Right-hand rule gradient -->
                                    <Rectangle Grid.Column="3" Height="1"
                                               VerticalAlignment="Center"
                                               Margin="14,0,0,0">
                                        <Rectangle.Fill>
                                            <LinearGradientBrush StartPoint="0,0" EndPoint="1,0">
                                                <GradientStop Color="{StaticResource BorderBrightColor}" Offset="0"/>
                                                <GradientStop Color="#00000000" Offset="1"/>
                                            </LinearGradientBrush>
                                        </Rectangle.Fill>
                                    </Rectangle>
                                </Grid>
                            </Border>
                            <!-- Body -->
                            <ContentPresenter Margin="18,14,18,18"/>
                        </DockPanel>
                    </Border>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

</ResourceDictionary>
